# ─────────────────────────────────────────────────────────────────
# Skill Evaluator Platform — Vercel SaaS Deployment
# ─────────────────────────────────────────────────────────────────
# 部署前必须在 Vercel Project Settings → Environment Variables
# 中配置以下变量，否则 Serverless Function 启动即 502。
# ─────────────────────────────────────────────────────────────────

# ─── 数据库（必填）──────────────────────────────────────────────
# Neon PostgreSQL 连接串
# 重要：必须带 ?sslmode=require，否则 Vercel 函数内连接会被 Neon 拒绝
# 推荐使用 Neon 的 -pooler 域名（连接池端点），降低冷启动延迟
# 示例：postgresql://user:pass@ep-xxx-pooler.us-east-2.aws.neon.tech/dbname?sslmode=require
DATABASE_URL=postgresql://user:password@host-pooler.region.aws.neon.tech/skill_evaluator?sslmode=require

# ─── 管理员 Token（必填）────────────────────────────────────────
# 用于 /api/init 数据库初始化端点鉴权
ADMIN_TOKEN=请生成一个强随机字符串

# ─── LLM API Keys（按需）───────────────────────────────────────
# 注意：前端用户也可在 UI 里自行填入，这里的值仅作为后端兜底
ANTHROPIC_API_KEY=sk-ant-...
OPENAI_API_KEY=sk-...
DEEPSEEK_API_KEY=sk-...
DOUBAO_API_KEY=...
QWEN_API_KEY=...
GEMINI_API_KEY=...

# ─── 运行环境（Vercel 自动注入，无需手动填）─────────────────────
# NODE_ENV=production
# VERCEL_ENV=production
# VERCEL_REGION=iad1

# ─── 前端构建期变量（VITE_ 前缀会打入 bundle）─────────────────
# 留空则前端用相对路径调用 /api/*，部署到同一域名最简单
VITE_API_BASE_URL=
VITE_APP_NAME=Skill Evaluator
VITE_APP_VERSION=2.0.0
