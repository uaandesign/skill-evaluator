# ─────────────────────────────────────────────────────────────────
# Skill Evaluator Platform — Vercel SaaS Deployment
# ─────────────────────────────────────────────────────────────────

# DATABASE
# Vercel Postgres: https://vercel.com/postgres
# Format: postgresql://user:password@host:5432/database
DATABASE_URL=postgresql://user:password@host:5432/skill_evaluator

# LLM API Keys (required for evaluation)
# OpenAI
OPENAI_API_KEY=sk-...

# Anthropic (Claude)
ANTHROPIC_API_KEY=sk-ant-...

# DeepSeek
DEEPSEEK_API_KEY=sk-...

# Doubao (ByteDance)
DOUBAO_API_KEY=...

# Qwen (Alibaba)
QWEN_API_KEY=...

# Google Gemini
GEMINI_API_KEY=...

# ADMIN
# Used for database initialization and admin endpoints
ADMIN_TOKEN=your-secure-admin-token-here

# NODE_ENV
NODE_ENV=production

# Frontend configuration
VITE_API_BASE_URL=https://your-domain.com
VITE_APP_NAME=Skill Evaluator
VITE_APP_VERSION=2.0.0
