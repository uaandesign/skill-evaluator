{
  "$schema": "https://openapi.vercel.sh/vercel.json",
  "version": 2,
  "framework": "vite",
  "functions": {
    "api/chat.js": { "maxDuration": 60 },
    "api/run-skill.js": { "maxDuration": 60 },
    "api/evaluate-skill.js": { "maxDuration": 300 },
    "api/skills.js": { "maxDuration": 30 },
    "api/init.js": { "maxDuration": 30 }
  },
  "headers": [
    {
      "source": "/(.*)",
      "headers": [
        { "key": "X-Frame-Options", "value": "ALLOWALL" },
        { "key": "Content-Security-Policy", "value": "frame-ancestors *" }
      ]
    }
  ]
}
